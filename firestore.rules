rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isManagerOrAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];
    }

    function isActiveUser() {
      return isAuth() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'Aktif'
      );
    }

    // ─── User profiles ────────────────────────────────────────
    match /users/{uid} {
      // Any authenticated user can read all profiles (needed for user list in admin)
      allow read: if isAuth();
      // Users can write their own profile; admins can write any
      allow write: if isAuth() && (request.auth.uid == uid || isAdmin());
    }

    // ─── App data (products, inventory, locations) ─────────────
    match /appdata/{doc} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ─── Transfer log ────────────────────────────────────────
    match /transferLog/{logId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isManagerOrAdmin();
    }

    // ─── Count logs ───────────────────────────────────────────
    match /countLogs/{logId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isManagerOrAdmin();
    }

    // ─── Activity log ──────────────────────────────────────────
    match /activityLog/{logId} {
      allow read: if isManagerOrAdmin();
      allow create: if isAuth();
      allow update, delete: if isManagerOrAdmin();
    }

    // ─── Deny all else ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
